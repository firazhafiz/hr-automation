generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id         String           @id @default(uuid())
  nik        String           @unique @db.VarChar(20)
  nama       String           @db.VarChar(100)
  email      String?          @unique
  password   String?
  bagian     String?          @db.VarChar(100)
  departemen String?          @db.VarChar(50)
  is_active  Boolean          @default(true)
  total_sp   Int              @default(0)
  total_cuti Int              @default(0)
  total_ijin Int              @default(0)
  created_at DateTime         @default(now())
  submissions FormSubmission[]
}

model FormSubmission {
  id               String    @id @default(uuid())
  jenis_form       String    @db.VarChar(10) // 'CUTI' | 'IJIN' | 'SP'
  image_url        String?
  raw_ocr_text     String?
  confidence_avg   Float?

  // Employee data (denormalized for display, linked via relation)
  employee_id      String?
  employee         Employee? @relation(fields: [employee_id], references: [id])
  nik_karyawan     String?   @db.VarChar(20)
  nama_karyawan    String    @db.VarChar(100)
  departemen       String?   @db.VarChar(50)
  bagian           String?   @db.VarChar(100)
  employee_matched Boolean   @default(false)

  // Form-specific fields
  tanggal_surat    DateTime? @db.Date // Tanggal form/surat dibuat
  tanggal_mulai    DateTime? @db.Date
  tanggal_selesai  DateTime? @db.Date
  keterangan       String?            // Dikarenakan (Cuti/Ijin)
  alasan           String?   @db.Text // Detail pelanggaran (SP)

  // Tanda Tangan Validation
  ttd_personalia   Boolean   @default(false)
  ttd_atasan       Boolean   @default(false) // Manager (SP) or Supervisor/Manager (Cuti)
  ttd_pemohon      Boolean   @default(false) // Supervisor (SP) or Pemohon (Cuti)
  ttd_lengkap      Boolean   @default(false) // All 3 signed = true

  is_deleted       Boolean   @default(false)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([jenis_form])
  @@index([jenis_form, tanggal_mulai])
  @@index([employee_id])
}

model AuditLog {
  id         String   @id @default(uuid())
  record_id  String
  action     String   @db.VarChar(20) // 'CREATE' | 'UPDATE' | 'DELETE'
  changed_by String   @default("admin") @db.VarChar(50)
  old_data   Json?
  new_data   Json?
  created_at DateTime @default(now())
}

// Tracks each scan API call for daily rate limiting
model ScanLog {
  id         String   @id @default(uuid())
  status     String   @default("success") @db.VarChar(10) // 'success' | 'error'
  created_at DateTime @default(now())

  @@index([created_at])
}
